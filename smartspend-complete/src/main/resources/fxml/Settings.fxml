<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartspend.controller.SettingsController"
            fitToWidth="true" styleClass="page">

    <VBox spacing="24" styleClass="page">
        <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

        <!-- ── Header ── -->
        <Label text="Settings" styleClass="page-title"/>

        <!-- ── Account section ── -->
        <VBox spacing="12" styleClass="tip-card">
            <Label text="ACCOUNT" styleClass="section-label"/>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Logged in as" styleClass="muted"/>
                    <Label fx:id="lblUsername" text="—" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1f2a1f;"/>
                    <Label fx:id="lblEmail" text="—" styleClass="muted"/>
                </VBox>
                <Button fx:id="btnSignOut" text="Sign out"
                        style="-fx-background-color: #f1f8f1; -fx-background-radius: 6; -fx-padding: 8 16 8 16; -fx-cursor: hand; -fx-border-color: #d8e8d8; -fx-border-radius: 6;"/>
            </HBox>
        </VBox>

        <!-- ── Shopping preferences ── -->
        <VBox spacing="16" styleClass="tip-card">
            <Label text="SHOPPING PREFERENCES" styleClass="section-label"/>

            <HBox spacing="24">
                <!-- Preferred store -->
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Preferred store" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1f2a1f;"/>
                    <ComboBox fx:id="cmbPreferredStore" maxWidth="Infinity">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Aldi"/>
                                <String fx:value="Coles"/>
                                <String fx:value="Woolworths"/>
                                <String fx:value="No preference"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <Label text="Used for store recommendations" styleClass="muted"/>
                </VBox>

                <!-- Weekly budget -->
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Weekly budget ($)" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1f2a1f;"/>
                    <TextField fx:id="txtWeeklyBudget" promptText="e.g. 100.00"/>
                    <Label text="Enter your weekly grocery budget" styleClass="muted"/>
                </VBox>
            </HBox>

            <HBox spacing="8">
                <Button fx:id="btnSavePreferences" text="Save preferences" styleClass="primary-button"/>
                <Button fx:id="btnCancelPreferences" text="Cancel"
                        style="-fx-background-color: #f1f8f1; -fx-background-radius: 6; -fx-padding: 8 16 8 16; -fx-cursor: hand; -fx-border-color: #d8e8d8; -fx-border-radius: 6;"/>
            </HBox>

            <!-- Save confirmation message -->
            <Label fx:id="lblSaveConfirm" text="" styleClass="muted-strong" managed="false" visible="false"/>
        </VBox>

        <!-- ── AI and recommendations ── -->
        <VBox spacing="12" styleClass="tip-card">
            <Label text="AI &amp; RECOMMENDATIONS" styleClass="section-label"/>

            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14;">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Show sale predictions" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1f2a1f;"/>
                    <Label text="Highlight items likely to go on sale soon" styleClass="muted"/>
                </VBox>
                <CheckBox fx:id="chkSalePredictions"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14;">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Show value suggestions" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1f2a1f;"/>
                    <Label text="Recommend cheaper alternative products" styleClass="muted"/>
                </VBox>
                <CheckBox fx:id="chkValueSuggestions"/>
            </HBox>
        </VBox>

        <!-- ── Database status ── -->
        <VBox spacing="12" styleClass="tip-card">
            <Label text="DATA &amp; STORAGE" styleClass="section-label"/>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Database status" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1f2a1f;"/>
                    <Label fx:id="lblDbStatus" text="Checking…" styleClass="muted"/>
                </VBox>
                <Region prefWidth="10" prefHeight="10" fx:id="dbStatusDot"
                        style="-fx-background-color: #d0d0d0; -fx-background-radius: 5;"/>
            </HBox>
            <Label text="All shopping data is saved locally to your device." styleClass="muted"/>
        </VBox>

    </VBox>
</ScrollPane>
