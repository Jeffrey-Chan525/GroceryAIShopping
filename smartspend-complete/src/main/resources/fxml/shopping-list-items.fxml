<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      spacing="8" style="-fx-background-color: #fafcfa;">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <!-- Toolbar -->
    <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #e8f5e8; -fx-border-color: #88a088; -fx-border-width: 2; -fx-padding: 8;">
        <Label text="Shopping List Items" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold;">
            <font>
                <Font name="Monospaced" size="14"/>
            </font>
        </Label>

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="+ Add Item" style="-fx-background-color: #7a9a7a; -fx-border-color: #5a7a5a; -fx-border-width: 2; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Filter" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-border-width: 2;"/>
        <Button text="Sort" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-border-width: 2;"/>
    </HBox>

    <!-- List Selection and Note -->
    <HBox alignment="CENTER_LEFT" spacing="4">
        <Button text="Main List" style="-fx-background-color: #7a9a7a; -fx-border-color: #5a7a5a; -fx-border-width: 2; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Save For Later" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-border-width: 2;"/>
        <Button text="Wishlist" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-border-width: 2;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Label text="Shopping lists are saved between sessions" style="-fx-text-fill: #5a6a5a;">
            <font>
                <Font name="Monospaced" size="9"/>
            </font>
        </Label>
    </HBox>

    <!-- Add/Edit Item Form -->
    <VBox spacing="8" style="-fx-background-color: white; -fx-border-color: #88a088; -fx-border-width: 2; -fx-padding: 8;">
        <Label text="ADD / EDIT ITEM" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold; -fx-border-color: #ccc; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 4 0;">
            <font>
                <Font name="Monospaced" size="10"/>
            </font>
        </Label>

        <GridPane hgap="8" vgap="4">
            <Label text="Item Name" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
            <TextField promptText="e.g. Milk" GridPane.columnIndex="0" GridPane.rowIndex="1" prefHeight="28" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>

            <Label text="Category" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
            <ComboBox promptText="Dairy" GridPane.columnIndex="1" GridPane.rowIndex="1" prefHeight="28" maxWidth="Infinity" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>

            <Label text="Quantity" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
            <TextField text="2" GridPane.columnIndex="2" GridPane.rowIndex="1" prefHeight="28" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>

            <Label text="Unit" GridPane.columnIndex="3" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
            <ComboBox promptText="L" GridPane.columnIndex="3" GridPane.rowIndex="1" prefHeight="28" maxWidth="Infinity" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>

            <Label text="Target Price" GridPane.columnIndex="4" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
            <TextField text="\$4.00" GridPane.columnIndex="4" GridPane.rowIndex="1" prefHeight="28" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>

            <Label text="Preferred Store" GridPane.columnIndex="5" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
            <ComboBox promptText="Aldi" GridPane.columnIndex="5" GridPane.rowIndex="1" prefHeight="28" maxWidth="Infinity" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>
        </GridPane>

        <HBox spacing="8" alignment="CENTER_LEFT">
            <Button text="Save Item" style="-fx-background-color: #7a9a7a; -fx-border-color: #5a7a5a; -fx-border-width: 2; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="Cancel" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-border-width: 2;"/>
            <Button text="Delete Item" style="-fx-background-color: #ddd; -fx-border-color: #999; -fx-border-width: 2;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <!-- Table -->
    <TableView VBox.vgrow="ALWAYS" style="-fx-border-color: #88a088; -fx-border-width: 2;">
        <columns>
            <TableColumn text="Item" prefWidth="200"/>
            <TableColumn text="Category" prefWidth="120"/>
            <TableColumn text="Qty" prefWidth="60"/>
            <TableColumn text="Target" prefWidth="90"/>
            <TableColumn text="Best Now" prefWidth="90"/>
            <TableColumn text="Price Per Unit" prefWidth="120"/>
            <TableColumn text="Store" prefWidth="100"/>
            <TableColumn text="Actions" prefWidth="80"/>
        </columns>
    </TableView>

    <!-- Bottom Summary -->
    <HBox spacing="12">
        <Label text="Saved to database" style="-fx-text-fill: #5a6a5a;"/>
        <Label text="Total best price: \$19.00" style="-fx-text-fill: #5a6a5a;"/>
    </HBox>

    <!-- Optional right-panel summary moved into bottom card -->
    <VBox spacing="6" style="-fx-background-color: #f5faf5; -fx-border-color: #88a088; -fx-border-width: 2; -fx-padding: 8;">
        <Label text="BASKET SUMMARY" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold;"/>
        <HBox spacing="20">
            <VBox spacing="4">
                <Label text="Estimated Basket Total" style="-fx-text-fill: #555;"/>
                <Label text="\$19.00" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Best Store Overall" style="-fx-text-fill: #555;"/>
                <Label text="Aldi" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold;"/>
                <Label text="Cheapest total for this list" style="-fx-text-fill: #666;"/>
            </VBox>
        </HBox>
    </VBox>
</VBox>