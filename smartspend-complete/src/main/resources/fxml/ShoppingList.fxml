<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartspend.controller.ShoppingListController"
      spacing="12" prefWidth="1000" prefHeight="700">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="SHOPPING LIST" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <HBox spacing="8">
        <TextField fx:id="itemField" promptText="Enter item" prefWidth="250"/>
        <TextField fx:id="priceField" promptText="Price" prefWidth="120"/>
        <Button text="Add Item" onAction="#handleAddItem"/>
    </HBox>

    <TableView fx:id="tableView" prefHeight="400">
        <columns>
            <TableColumn fx:id="itemCol" text="Item" prefWidth="300"/>
            <TableColumn fx:id="priceCol" text="Price" prefWidth="150"/>
        </columns>
    </TableView>

    <Label fx:id="totalLabel" text="Total: $0.00"/>
</VBox>