<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartspend.controller.PriceHistoryController"
            styleClass="root-pane">

    <!-- ===== Main content ===== -->
    <center>
        <VBox spacing="18" styleClass="page">
            <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Price history" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="itemCombo" prefWidth="160"/>
                <ComboBox fx:id="rangeCombo" prefWidth="160"/>
            </HBox>


            <TableView fx:id="priceTable" prefHeight="200" styleClass="clean-table">
                <columns>
                    <TableColumn fx:id="colWeek"    text="Week"       prefWidth="200"/>
                    <TableColumn fx:id="colAldi"    text="Aldi"       prefWidth="160"/>
                    <TableColumn fx:id="colColes"   text="Coles"      prefWidth="160"/>
                    <TableColumn fx:id="colWoolies" text="Woolworths" prefWidth="180"/>
                    <TableColumn fx:id="colLowest"  text="Lowest"     prefWidth="140"/>
                    <TableColumn fx:id="colChange"  text="Change"     prefWidth="140"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <VBox styleClass="tip-card" spacing="4">
                <Label text="Trend insight" styleClass="tip-label"/>
                <Label text="Aldi milk trending down (−7% over 3 months). No price spikes detected." styleClass="tip-text"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
