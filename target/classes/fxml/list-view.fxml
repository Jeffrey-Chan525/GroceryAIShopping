<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartspend.controller.ListViewController"
      spacing="16" styleClass="root" prefWidth="1100" prefHeight="720">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="12">
        <Label text="SHOPPING LIST / PRICE MATRIX" styleClass="title" />
        <Button fx:id="backButton" text="Back to Dashboard" onAction="#handleBack" />
    </HBox>

    <VBox spacing="8" styleClass="card">
        <Label text="Template Screen" styleClass="subtitle" />
        <Label wrapText="true" text="This is Hayden's UI template for the main shopping list and price comparison screen. Edit labels, buttons, and table columns later without needing to rebuild the layout from scratch." />
    </VBox>

    <TableView prefHeight="420">
        <columns>
            <TableColumn text="Item" prefWidth="180" />
            <TableColumn text="Qty" prefWidth="70" />
            <TableColumn text="Coles" prefWidth="110" />
            <TableColumn text="Woolworths" prefWidth="110" />
            <TableColumn text="Aldi" prefWidth="110" />
            <TableColumn text="Cheapest" prefWidth="120" />
            <TableColumn text="Status" prefWidth="120" />
            <TableColumn text="Actions" prefWidth="150" />
        </columns>
    </TableView>

    <HBox spacing="16">
        <VBox spacing="8" styleClass="card" prefWidth="260">
            <Label text="Basket at Coles" styleClass="subtitle" />
            <Label text="$0.00" />
        </VBox>
        <VBox spacing="8" styleClass="card" prefWidth="260">
            <Label text="Basket at Woolworths" styleClass="subtitle" />
            <Label text="$0.00" />
        </VBox>
        <VBox spacing="8" styleClass="card" prefWidth="260">
            <Label text="Basket at Aldi" styleClass="subtitle" />
            <Label text="$0.00" />
        </VBox>
        <VBox spacing="8" styleClass="card" prefWidth="260">
            <Label text="Cheapest Basket" styleClass="subtitle" />
            <Label text="Template Result" />
        </VBox>
    </HBox>
</VBox>
