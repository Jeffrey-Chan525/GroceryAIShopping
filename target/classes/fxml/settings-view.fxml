<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartspend.controller.SettingsController"
            prefWidth="1440"
            prefHeight="900"
            style="-fx-background-color: #f4f7f2;">

    <left>
        <VBox prefWidth="250"
              spacing="14"
              style="-fx-background-color: #183f2e;">
            <padding>
                <Insets top="24" right="18" bottom="24" left="18"/>
            </padding>

            <Label text="SmartSpend"
                   style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>

            <Label text="AI-supported grocery planning for students"
                   wrapText="true"
                   style="-fx-text-fill: #d7eadf; -fx-font-size: 13px;"/>

            <VBox spacing="8">
                <Button text="Dashboard" onAction="#goDashboard" maxWidth="Infinity"/>
                <Button text="Shopping List" onAction="#goShoppingList" maxWidth="Infinity"/>
                <Button text="Price Comparison" onAction="#goComparison" maxWidth="Infinity"/>
                <Button text="Budget" onAction="#goBudget" maxWidth="Infinity"/>
                <Button text="AI Assistant" onAction="#goAiChat" maxWidth="Infinity"/>
                <Button text="Prices" onAction="#goPrices" maxWidth="Infinity"/>
                <Button text="Pantry" onAction="#goPantry" maxWidth="Infinity"/>
                <Button text="Settings" onAction="#goSettings" maxWidth="Infinity"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8"
                  style="-fx-background-color: rgba(255,255,255,0.12); -fx-background-radius: 12;">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>

                <Label text="Project Theme"
                       style="-fx-text-fill: white; -fx-font-weight: bold;"/>

                <Label text="Living, Learning, Working with AI"
                       wrapText="true"
                       style="-fx-text-fill: #d7eadf;"/>
            </VBox>

            <Button text="Log Out" onAction="#goLogin" maxWidth="Infinity"/>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="16"
              style="-fx-background-color: white; -fx-border-color: transparent transparent #dce5dc transparent;">
            <padding>
                <Insets top="20" right="28" bottom="20" left="28"/>
            </padding>

            <VBox spacing="4">
                <Label text="Settings"
                       style="-fx-text-fill: #183f2e; -fx-font-size: 30px; -fx-font-weight: bold;"/>

                <Label text="Personalise SmartSpend so recommendations fit your shopping habits."
                       style="-fx-text-fill: #60766b; -fx-font-size: 14px;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField promptText="Search within SmartSpend"
                       prefWidth="260"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox spacing="22">
                    <padding>
                        <Insets top="28" right="28" bottom="28" left="28"/>
                    </padding>

                    <VBox spacing="16"
                          maxWidth="780"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0.2, 0, 4);">
                        <padding>
                            <Insets top="24" right="24" bottom="24" left="24"/>
                        </padding>

                        <Label text="Personal Settings"
                               style="-fx-text-fill: #183f2e; -fx-font-size: 22px; -fx-font-weight: bold;"/>

                        <Label text="These settings control the demo user preferences for budget, store choice, and recommendation options."
                               wrapText="true"
                               style="-fx-text-fill: #60766b; -fx-font-size: 14px;"/>

                        <GridPane hgap="18" vgap="18">
                            <columnConstraints>
                                <ColumnConstraints minWidth="170"/>
                                <ColumnConstraints minWidth="260" hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Weekly Budget"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="0"
                                   style="-fx-text-fill: #183f2e; -fx-font-weight: bold;"/>

                            <TextField fx:id="weeklyBudgetField"
                                       promptText="100.00"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="0"/>

                            <Label text="Primary Store"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="1"
                                   style="-fx-text-fill: #183f2e; -fx-font-weight: bold;"/>

                            <ComboBox fx:id="primaryStoreCombo"
                                      prefWidth="260"
                                      GridPane.columnIndex="1"
                                      GridPane.rowIndex="1"/>

                            <CheckBox fx:id="salePredictionsCheck"
                                      text="Show sale predictions"
                                      GridPane.columnIndex="0"
                                      GridPane.rowIndex="2"
                                      selected="true"/>

                            <CheckBox fx:id="valueSuggestionsCheck"
                                      text="Show value suggestions"
                                      GridPane.columnIndex="1"
                                      GridPane.rowIndex="2"
                                      selected="true"/>

                            <CheckBox fx:id="pantryRemindersCheck"
                                      text="Enable pantry reminders"
                                      GridPane.columnIndex="0"
                                      GridPane.rowIndex="3"
                                      selected="true"/>
                        </GridPane>

                        <HBox spacing="10">
                            <Button text="Save Changes"
                                    onAction="#handleSaveChanges"
                                    style="-fx-background-color: #183f2e; -fx-text-fill: white; -fx-font-weight: bold;"/>

                            <Button text="Reset to Defaults"
                                    onAction="#handleResetDefaults"/>
                        </HBox>

                        <Label fx:id="statusLabel"
                               text="Settings ready."
                               wrapText="true"
                               style="-fx-text-fill: #60766b; -fx-font-size: 13px;"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>