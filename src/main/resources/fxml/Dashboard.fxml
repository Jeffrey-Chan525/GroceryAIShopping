<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartspend.controller.DashboardController"
      spacing="18" styleClass="page">
    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <HBox alignment="CENTER_LEFT">
        <Label text="Hello User!" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ New shopping list" styleClass="primary-button"/>
    </HBox>

    <HBox spacing="16">
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <Label text="Weekly budget" styleClass="card-label"/>
            <Label text="\$120" styleClass="card-value"/>
            <Label text="Set by you" styleClass="card-sub"/>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <Label text="Basket total" styleClass="card-label"/>
            <Label text="\$84.50" styleClass="card-value"/>
            <Label text="\$35.50 left" styleClass="card-sub"/>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <Label text="Items in list" styleClass="card-label"/>
            <Label text="14" styleClass="card-value"/>
            <Label text="3 still needed" styleClass="card-sub"/>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <Label text="Best store" styleClass="card-label"/>
            <Label text="Aldi" styleClass="card-value"/>
            <Label text="saves \$11.40" styleClass="card-sub"/>
        </VBox>
    </HBox>

    <VBox spacing="6">
        <HBox>
            <Label text="Budget used — 70%" styleClass="muted"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="On track" styleClass="muted-strong"/>
        </HBox>
        <ProgressBar progress="0.7" maxWidth="Infinity" styleClass="budget-bar"/>
    </VBox>

    <VBox styleClass="tip-card" spacing="4">
        <Label text="AI tip" styleClass="tip-label"/>
        <Label text="Switch milk &amp; eggs to Aldi — saves \$4.20. Pasta at 3-month low, stock up." styleClass="tip-text"/>
    </VBox>

    <Label text="RECENT ITEMS" styleClass="section-label"/>
    <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS" styleClass="clean-table">
        <columns>
            <TableColumn fx:id="colName"   text="Item"       prefWidth="360"/>
            <TableColumn fx:id="colQty"    text="Qty"        prefWidth="100"/>
            <TableColumn fx:id="colPrice"  text="Best price" prefWidth="140"/>
            <TableColumn fx:id="colStore"  text="Store"      prefWidth="180"/>
            <TableColumn fx:id="colStatus" text="Status"     prefWidth="160"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
