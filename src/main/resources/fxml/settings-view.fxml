<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartspend.controller.SettingsController"
            prefWidth="1440"
            prefHeight="900"
            styleClass="app-root">

    <left>
        <VBox prefWidth="250" spacing="14" styleClass="sidebar">
            <padding>
                <Insets top="24" right="18" bottom="24" left="18"/>
            </padding>

            <Label text="SmartSpend" styleClass="brand"/>
            <Label text="AI-driven grocery planning for students" styleClass="brand-subtitle" wrapText="true"/>

            <VBox spacing="8" styleClass="nav-group">
                <Button text="Dashboard" onAction="#goDashboard" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Shopping List" onAction="#goShoppingList" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Price Comparison" onAction="#goComparison" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Budget" onAction="#goBudget" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="AI Assistant" onAction="#goAiChat" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Prices" onAction="#goPrices" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Pantry" onAction="#goPantry" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Settings" onAction="#goSettings" maxWidth="Infinity" styleClass="nav-button"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8" styleClass="sidebar-card">
                <Label text="Project Theme" styleClass="sidebar-card-title"/>
                <Label text="Living, Learning, Working with AI" wrapText="true" styleClass="sidebar-card-body"/>
            </VBox>

            <Button text="Log Out" onAction="#goLogin" maxWidth="Infinity" styleClass="ghost-button"/>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar">
            <padding>
                <Insets top="20" right="28" bottom="20" left="28"/>
            </padding>

            <VBox spacing="4">
                <Label text="Settings" styleClass="page-title"/>
                <Label text="Manage your weekly budget, preferred store, and recommendation options."
                       styleClass="page-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField promptText="Search within SmartSpend"
                       prefWidth="260"
                       styleClass="search-field"/>

            <Button text="Notifications" styleClass="secondary-button"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    styleClass="content-scroll">
            <content>
                <VBox spacing="22" styleClass="content-area">
                    <padding>
                        <Insets top="28" right="28" bottom="28" left="28"/>
                    </padding>

                    <VBox spacing="18" maxWidth="760" styleClass="surface-card">
                        <Label text="Preference Settings" styleClass="section-title"/>

                        <GridPane hgap="18" vgap="18">
                            <columnConstraints>
                                <ColumnConstraints minWidth="170"/>
                                <ColumnConstraints minWidth="320" hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Weekly Budget"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="0"
                                   styleClass="muted-label"/>

                            <TextField fx:id="weeklyBudgetField"
                                       promptText="100.00"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="0"
                                       styleClass="app-input"/>

                            <Label text="Primary Store"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="1"
                                   styleClass="muted-label"/>

                            <ComboBox fx:id="primaryStoreCombo"
                                      prefWidth="320"
                                      GridPane.columnIndex="1"
                                      GridPane.rowIndex="1"
                                      styleClass="app-combo"/>

                            <Label text="AI Features"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="2"
                                   styleClass="muted-label"/>

                            <VBox spacing="10"
                                  GridPane.columnIndex="1"
                                  GridPane.rowIndex="2">
                                <CheckBox fx:id="salePredictionsCheck"
                                          text="Show sale predictions"
                                          selected="true"/>

                                <CheckBox fx:id="valueSuggestionsCheck"
                                          text="Show value suggestions"
                                          selected="true"/>

                                <CheckBox fx:id="pantryRemindersCheck"
                                          text="Enable pantry reminders"
                                          selected="true"/>
                            </VBox>
                        </GridPane>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button text="Save Changes"
                                    onAction="#handleSaveChanges"
                                    styleClass="primary-button"/>

                            <Button text="Reset to Defaults"
                                    onAction="#handleResetDefaults"
                                    styleClass="secondary-button"/>
                        </HBox>

                        <Label fx:id="statusLabel"
                               text="Settings ready."
                               wrapText="true"
                               styleClass="status-pill"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>