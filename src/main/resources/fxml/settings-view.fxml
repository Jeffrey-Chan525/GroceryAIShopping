<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartspend.controller.SettingsController"
            prefWidth="1440" prefHeight="900"
            styleClass="app-root">

    <left>
        <VBox prefWidth="250" spacing="14" styleClass="sidebar">
            <padding>
                <Insets top="24" right="18" bottom="24" left="18"/>
            </padding>

            <Label text="SmartSpend" styleClass="brand"/>
            <Label text="AI-supported grocery planning for students"
                   styleClass="brand-subtitle"
                   wrapText="true"/>

            <VBox spacing="8" styleClass="nav-group">
                <Button text="Dashboard" onAction="#goDashboard" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Shopping List" onAction="#goShoppingList" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Price Comparison" onAction="#goComparison" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Budget" onAction="#goBudget" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="AI Assistant" onAction="#goAiChat" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Prices" onAction="#goPrices" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Pantry" onAction="#goPantry" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Settings" onAction="#goSettings" maxWidth="Infinity" styleClass="nav-button"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8" styleClass="sidebar-card">
                <Label text="Project Theme" styleClass="sidebar-card-title"/>
                <Label text="Living, Learning, Working with AI"
                       wrapText="true"
                       styleClass="sidebar-card-body"/>
            </VBox>

            <Button text="Log Out" onAction="#goLogin" maxWidth="Infinity" styleClass="ghost-button"/>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar">
            <padding>
                <Insets top="20" right="28" bottom="20" left="28"/>
            </padding>

            <VBox spacing="4">
                <Label text="Settings" styleClass="page-title"/>
                <Label text="Personalise SmartSpend so recommendations fit your shopping habits."
                       styleClass="page-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField promptText="Search within SmartSpend"
                       prefWidth="260"
                       styleClass="search-field"/>
            <Button text="Alerts" styleClass="secondary-button"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    styleClass="content-scroll">
            <content>
                <VBox spacing="22" styleClass="content-area">
                    <padding>
                        <Insets top="28" right="28" bottom="28" left="28"/>
                    </padding>

                    <VBox spacing="14" styleClass="surface-card">
                        <Label text="Personal Settings" styleClass="section-title"/>

                        <GridPane hgap="18" vgap="18">
                            <Label text="Weekly Budget" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="field-label"/>
                            <TextField text="\$100.00" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="app-input"/>

                            <Label text="Primary Store" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="field-label"/>
                            <ComboBox promptText="Aldi" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="app-combo" prefWidth="220"/>

                            <CheckBox text="Show sale predictions" GridPane.columnIndex="0" GridPane.rowIndex="2" selected="true" styleClass="app-check"/>
                            <CheckBox text="Show value suggestions" GridPane.columnIndex="1" GridPane.rowIndex="2" selected="true" styleClass="app-check"/>
                            <CheckBox text="Enable pantry reminders" GridPane.columnIndex="0" GridPane.rowIndex="3" selected="true" styleClass="app-check"/>
                        </GridPane>

                        <HBox spacing="10">
                            <Button text="Save Changes" styleClass="primary-button"/>
                            <Button text="Reset to Defaults" styleClass="ghost-button"/>
                        </HBox>

                        <Label text="Keep this page simple for the checkpoint. It supports the user_preferences side of your database design."
                               wrapText="true"
                               styleClass="muted-label"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>