<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartspend.controller.BudgetController"
            prefWidth="1440" prefHeight="900"
            styleClass="app-root">

    <left>
        <VBox prefWidth="250" spacing="14" styleClass="sidebar">
            <padding>
                <Insets top="24" right="18" bottom="24" left="18"/>
            </padding>

            <Label text="SmartSpend" styleClass="brand"/>
            <Label text="AI-supported grocery planning for students"
                   styleClass="brand-subtitle"
                   wrapText="true"/>

            <VBox spacing="8" styleClass="nav-group">
                <Button text="Dashboard" onAction="#goDashboard" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Shopping List" onAction="#goShoppingList" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Price Comparison" onAction="#goComparison" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Budget" onAction="#goBudget" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="AI Assistant" onAction="#goAiChat" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Prices" onAction="#goPrices" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Pantry" onAction="#goPantry" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Settings" onAction="#goSettings" maxWidth="Infinity" styleClass="nav-button"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8" styleClass="sidebar-card">
                <Label text="Project Theme" styleClass="sidebar-card-title"/>
                <Label text="Living, Learning, Working with AI"
                       wrapText="true"
                       styleClass="sidebar-card-body"/>
            </VBox>

            <Button text="Log Out" onAction="#goLogin" maxWidth="Infinity" styleClass="ghost-button"/>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar">
            <padding>
                <Insets top="20" right="28" bottom="20" left="28"/>
            </padding>

            <VBox spacing="4">
                <Label text="Budget Tracker" styleClass="page-title"/>
                <Label text="Keep an eye on your weekly grocery limit and see how recommendations help you stay on track."
                       styleClass="page-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField promptText="Search within SmartSpend"
                       prefWidth="260"
                       styleClass="search-field"/>
            <Button text="Alerts" styleClass="secondary-button"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    styleClass="content-scroll">
            <content>
                <VBox spacing="22" styleClass="content-area">
                    <padding>
                        <Insets top="28" right="28" bottom="28" left="28"/>
                    </padding>

                    <HBox spacing="18">
                        <VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="surface-card accent-green-light">
                            <Label text="Weekly Limit" styleClass="section-title"/>
                            <Label text="\$100" styleClass="metric-value small"/>
                            <ProgressBar progress="0.72" prefWidth="320" styleClass="budget-bar"/>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="surface-card accent-pink-light">
                            <Label text="Remaining This Week" styleClass="section-title"/>
                            <Label text="\$27.60" styleClass="metric-value small"/>
                            <Label text="You are still comfortably under budget."
                                   wrapText="true"
                                   styleClass="muted-label"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="14" styleClass="surface-card">
                        <Label text="Budget Planner" styleClass="section-title"/>

                        <GridPane hgap="14" vgap="14">
                            <Label text="Budget Name" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="field-label"/>
                            <TextField text="Weekly Student Shop" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="app-input"/>

                            <Label text="Target Limit" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="field-label"/>
                            <TextField text="\$100.00" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="app-input"/>

                            <Label text="Preferred Store" GridPane.columnIndex="2" GridPane.rowIndex="0" styleClass="field-label"/>
                            <ComboBox promptText="Aldi" GridPane.columnIndex="2" GridPane.rowIndex="1" styleClass="app-combo" prefWidth="180"/>
                        </GridPane>

                        <Label text="This page ties directly into your user_preferences table and supports the AI budgeting theme."
                               wrapText="true"
                               styleClass="muted-label"/>

                        <HBox spacing="10">
                            <Button text="Save Budget" styleClass="primary-button"/>
                            <Button text="Reset" styleClass="ghost-button"/>
                        </HBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>