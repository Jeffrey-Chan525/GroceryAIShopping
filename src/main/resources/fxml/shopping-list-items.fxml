<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            prefHeight="800.0" prefWidth="1280.0" style="-fx-background-color: #fafcfa;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #d4e4d4; -fx-border-color: #88a088; -fx-border-width: 0 0 2 0;" prefHeight="56.0">
            <padding>
                <Insets left="24" right="24" top="8" bottom="8"/>
            </padding>
            <Label text="SmartSpend - Shopping List Items" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold;">
                <font>
                    <Font name="Monospaced" size="18"/>
                </font>
            </Label>
        </HBox>
    </top>

    <left>
        <VBox spacing="4" style="-fx-background-color: #f0f5f0; -fx-border-color: #88a088; -fx-border-width: 0 2 0 0;" prefWidth="176">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label text="MENU" style="-fx-text-fill: #5a6a5a; -fx-font-weight: bold;">
                <font>
                    <Font name="Monospaced" size="10"/>
                </font>
            </Label>

            <Region prefHeight="8"/>

            <Button text="Dashboard" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-text-fill: #333;">
                <font>
                    <Font name="Monospaced" size="12"/>
                </font>
            </Button>

            <Button text="My Items" maxWidth="Infinity" style="-fx-background-color: #7a9a7a; -fx-border-color: #5a7a5a; -fx-border-width: 2; -fx-text-fill: white; -fx-font-weight: bold;">
                <font>
                    <Font name="Monospaced" size="12"/>
                </font>
            </Button>

            <Button text="Price Compare" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-text-fill: #333;">
                <font>
                    <Font name="Monospaced" size="12"/>
                </font>
            </Button>

            <Button text="Cart &amp; Budget" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-text-fill: #333;">
                <font>
                    <Font name="Monospaced" size="12"/>
                </font>
            </Button>

            <Button text="AI Advisor" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-text-fill: #333;">
                <font>
                    <Font name="Monospaced" size="12"/>
                </font>
            </Button>

            <Button text="Price History" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-text-fill: #333;">
                <font>
                    <Font name="Monospaced" size="12"/>
                </font>
            </Button>

            <Button text="Pantry" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-text-fill: #333;">
                <font>
                    <Font name="Monospaced" size="12"/>
                </font>
            </Button>

            <Button text="Settings" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-text-fill: #333;">
                <font>
                    <Font name="Monospaced" size="12"/>
                </font>
            </Button>

            <Region VBox.vgrow="ALWAYS"/>

            <Label text="JavaFX VBox + Buttons" wrapText="true" style="-fx-border-color: #88a088; -fx-border-style: dashed; -fx-text-fill: #5a6a5a; -fx-padding: 8;">
                <font>
                    <Font name="Monospaced" size="9"/>
                </font>
            </Label>
        </VBox>
    </left>

    <center>
        <VBox spacing="8" style="-fx-background-color: #fafcfa;">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #e8f5e8; -fx-border-color: #88a088; -fx-border-width: 2; -fx-padding: 8;">
                <Label text="Shopping List Items" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold;">
                    <font>
                        <Font name="Monospaced" size="14"/>
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="+ Add Item" style="-fx-background-color: #7a9a7a; -fx-border-color: #5a7a5a; -fx-border-width: 2; -fx-text-fill: white; -fx-font-weight: bold;">
                    <font>
                        <Font name="Monospaced" size="12"/>
                    </font>
                </Button>

                <Button text="Filter" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-border-width: 2;">
                    <font>
                        <Font name="Monospaced" size="12"/>
                    </font>
                </Button>

                <Button text="Sort" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-border-width: 2;">
                    <font>
                        <Font name="Monospaced" size="12"/>
                    </font>
                </Button>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="4">
                <Button text="Main List" style="-fx-background-color: #7a9a7a; -fx-border-color: #5a7a5a; -fx-border-width: 2; -fx-text-fill: white; -fx-font-weight: bold;">
                    <font>
                        <Font name="Monospaced" size="10"/>
                    </font>
                </Button>

                <Button text="Save For Later" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-border-width: 2;">
                    <font>
                        <Font name="Monospaced" size="10"/>
                    </font>
                </Button>

                <Button text="Wishlist" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-border-width: 2;">
                    <font>
                        <Font name="Monospaced" size="10"/>
                    </font>
                </Button>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="Shopping lists are saved between sessions" style="-fx-text-fill: #5a6a5a;">
                    <font>
                        <Font name="Monospaced" size="9"/>
                    </font>
                </Label>
            </HBox>

            <VBox spacing="8" style="-fx-background-color: white; -fx-border-color: #88a088; -fx-border-width: 2; -fx-padding: 8;">
                <Label text="ADD / EDIT ITEM" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold; -fx-border-color: #ccc; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 4 0;">
                    <font>
                        <Font name="Monospaced" size="10"/>
                    </font>
                </Label>

                <GridPane hgap="8" vgap="4">
                    <Label text="Item Name" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
                    <TextField promptText="e.g. Milk" GridPane.columnIndex="0" GridPane.rowIndex="1" prefHeight="28" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>

                    <Label text="Category" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
                    <ComboBox promptText="Dairy" GridPane.columnIndex="1" GridPane.rowIndex="1" prefHeight="28" maxWidth="Infinity" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>

                    <Label text="Quantity" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
                    <TextField text="2" GridPane.columnIndex="2" GridPane.rowIndex="1" prefHeight="28" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>

                    <Label text="Unit" GridPane.columnIndex="3" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
                    <ComboBox promptText="L" GridPane.columnIndex="3" GridPane.rowIndex="1" prefHeight="28" maxWidth="Infinity" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>

                    <Label text="Target Price" GridPane.columnIndex="4" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
                    <TextField text="\$4.00" GridPane.columnIndex="4" GridPane.rowIndex="1" prefHeight="28" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>

                    <Label text="Preferred Store" GridPane.columnIndex="5" GridPane.rowIndex="0" style="-fx-text-fill: #555;"/>
                    <ComboBox promptText="Aldi" GridPane.columnIndex="5" GridPane.rowIndex="1" prefHeight="28" maxWidth="Infinity" style="-fx-background-color: #fafafa; -fx-border-color: #aaa;"/>
                </GridPane>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button text="Save Item" style="-fx-background-color: #7a9a7a; -fx-border-color: #5a7a5a; -fx-border-width: 2; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Button text="Cancel" style="-fx-background-color: white; -fx-border-color: #aaa; -fx-border-width: 2;"/>
                    <Button text="Delete Item" style="-fx-background-color: #ddd; -fx-border-color: #999; -fx-border-width: 2;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="JavaFX TextField, ComboBox, Buttons" style="-fx-border-color: #88a088; -fx-border-style: dashed; -fx-text-fill: #5a6a5a; -fx-padding: 4;"/>
                </HBox>
            </VBox>

            <TableView VBox.vgrow="ALWAYS" style="-fx-border-color: #88a088; -fx-border-width: 2;">
                <columns>
                    <TableColumn text="Item" prefWidth="200"/>
                    <TableColumn text="Category" prefWidth="120"/>
                    <TableColumn text="Qty" prefWidth="60"/>
                    <TableColumn text="Target" prefWidth="90"/>
                    <TableColumn text="Best Now" prefWidth="90"/>
                    <TableColumn text="Price Per Unit" prefWidth="120"/>
                    <TableColumn text="Store" prefWidth="100"/>
                    <TableColumn text="Actions" prefWidth="80"/>
                </columns>
            </TableView>

            <Label text="JavaFX TableView - Shows item details, best current prices, and price per unit" style="-fx-border-color: #88a088; -fx-border-style: dashed; -fx-text-fill: #5a6a5a; -fx-padding: 4;"/>

            <HBox spacing="12">
                <Label text="Saved to database" style="-fx-text-fill: #5a6a5a;"/>
                <Label text="Total best price: $19.00" style="-fx-text-fill: #5a6a5a;"/>
            </HBox>
        </VBox>
    </center>

    <right>
        <VBox spacing="8" style="-fx-background-color: #f5faf5; -fx-border-color: #88a088; -fx-border-width: 0 0 0 2;" prefWidth="208">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label text="BASKET SUMMARY" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold; -fx-border-color: #88a088; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 8 0;"/>

            <VBox spacing="4" style="-fx-background-color: white; -fx-border-color: #88a088; -fx-border-width: 2; -fx-padding: 8;">
                <Label text="Estimated Basket Total" style="-fx-text-fill: #555;"/>
                <Label text="\$19.00" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="4" style="-fx-background-color: white; -fx-border-color: #88a088; -fx-border-width: 2; -fx-padding: 8;">
                <Label text="Basket Total by Store" style="-fx-text-fill: #555; -fx-font-weight: bold;"/>

                <HBox alignment="CENTER_LEFT">
                    <Label text="Aldi:" style="-fx-text-fill: #666;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="\$6.00" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <Label text="Coles:" style="-fx-text-fill: #666;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="\$6.50" style="-fx-text-fill: #2d4a2d;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <Label text="Woolworths:" style="-fx-text-fill: #666;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="\$7.50" style="-fx-text-fill: #2d4a2d;"/>
                </HBox>
            </VBox>

            <VBox spacing="4" style="-fx-background-color: #e8f5e8; -fx-border-color: #7a9a7a; -fx-border-width: 2; -fx-padding: 8;">
                <Label text="Best Store Overall" style="-fx-text-fill: #555; -fx-font-weight: bold;"/>
                <Label text="Aldi" style="-fx-text-fill: #2d4a2d; -fx-font-weight: bold;"/>
                <Label text="Cheapest total for this list" style="-fx-text-fill: #666;"/>
            </VBox>

            <Label text="JavaFX Labels" wrapText="true" style="-fx-border-color: #88a088; -fx-border-style: dashed; -fx-text-fill: #5a6a5a; -fx-padding: 8;"/>
        </VBox>
    </right>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #d4e4d4; -fx-border-color: #88a088; -fx-border-width: 2 0 0 0;" prefHeight="28">
            <Label text="Low-to-Medium Fidelity Wireframe - SmartSpend - Shopping List Items (1280x800)" style="-fx-text-fill: #5a6a5a;"/>
        </HBox>
    </bottom>

</BorderPane>