<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartspend.controller.DashboardV1Controller"
      spacing="16" styleClass="root" prefWidth="1000" prefHeight="650">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="12">
        <Label text="SMARTSPEND" styleClass="title" />
        <Button text="Settings" />
    </HBox>

    <HBox spacing="10">
        <TextField promptText="Quick Add Item" prefWidth="320" />
        <Button text="Add" />
    </HBox>

    <HBox spacing="16">
        <VBox spacing="8" styleClass="card" prefWidth="300">
            <Label fx:id="budgetLabel" text="Weekly Budget: $100.00" />
            <ProgressBar progress="0.72" prefWidth="260" />
        </VBox>
        <VBox spacing="8" styleClass="card" prefWidth="300">
            <Label fx:id="totalLabel" text="Current Basket Total: $72.40" />
            <Label text="Remaining: $27.60" />
        </VBox>
    </HBox>

    <VBox spacing="8" styleClass="card" prefWidth="620">
        <Label text="Frugal Briefing" styleClass="subtitle" />
        <Label fx:id="briefingLabel" wrapText="true" text="Your basket is cheapest at Aldi this week." />
    </VBox>

    <HBox spacing="10">
        <Button text="View Shopping List" />
        <Button text="View Price Trends" />
    </HBox>
</VBox>
