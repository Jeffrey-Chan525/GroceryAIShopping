<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartspend.controller.DashboardController"
            prefWidth="1440" prefHeight="900" styleClass="app-root">

    <left>
        <VBox prefWidth="240" spacing="14" styleClass="sidebar">
            <padding><Insets top="24" right="18" bottom="24" left="18"/></padding>

            <Label text="SmartSpend" styleClass="brand"/>
            <Label text="AI-driven grocery planning for students"
                   styleClass="brand-subtitle" wrapText="true"/>

            <VBox spacing="8" styleClass="nav-group">
                <Button text="Dashboard"        onAction="#goDashboard"    maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Shopping List"    onAction="#goShoppingList" maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Price Comparison" onAction="#goComparison"   maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Budget"           onAction="#goBudget"       maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="AI Assistant"     onAction="#goAiChat"       maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Prices"           onAction="#goPrices"       maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Pantry"           onAction="#goPantry"       maxWidth="Infinity" styleClass="nav-button"/>
                <Button text="Settings"         onAction="#goSettings"     maxWidth="Infinity" styleClass="nav-button"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="6" styleClass="sidebar-card">
                <Label text="Project Theme" styleClass="sidebar-card-title"/>
                <Label text="Living, Learning, Working with AI"
                       wrapText="true" styleClass="sidebar-card-body"/>
            </VBox>

            <Button text="Log Out" onAction="#goLogin"
                    maxWidth="Infinity" styleClass="ghost-button"/>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar">
            <padding><Insets top="20" right="28" bottom="20" left="28"/></padding>
            <VBox spacing="4">
                <Label text="Dashboard" styleClass="page-title"/>
                <Label text="A high-fidelity overview of budget, AI insights, and real product import."
                       styleClass="page-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField promptText="Search within SmartSpend" prefWidth="260"
                       styleClass="search-field"/>
            <Button text="Notifications" styleClass="secondary-button"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER"
                    styleClass="content-scroll">
            <content>
                <VBox spacing="22" styleClass="content-area">
                    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

                    <!-- ===== Top metric row ===== -->
                    <HBox spacing="18">
                        <VBox HBox.hgrow="ALWAYS" minWidth="260" prefWidth="320"
                              spacing="10" styleClass="metric-card accent-green">
                            <Label text="Weekly Budget" styleClass="metric-title"/>
                            <Label fx:id="budgetLabel" text="\$100.00"
                                   styleClass="metric-value"/>
                            <ProgressBar progress="0.72" maxWidth="Infinity"
                                         styleClass="budget-bar"/>
                            <Label text="72% of weekly budget used"
                                   styleClass="muted-label"/>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS" minWidth="260" prefWidth="320"
                              spacing="10" styleClass="metric-card accent-teal">
                            <Label text="Current Basket" styleClass="metric-title"/>
                            <Label fx:id="totalLabel" text="\$72.40"
                                   styleClass="metric-value"/>
                            <Label text="3 stores monitored this week"
                                   styleClass="muted-label"/>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS" minWidth="260" prefWidth="320"
                              spacing="10" styleClass="metric-card accent-gold">
                            <Label text="Imported Products" styleClass="metric-title"/>
                            <Label fx:id="importedCountLabel" text="0"
                                   styleClass="metric-value"/>
                            <Label text="Pulled from Open Food Facts"
                                   styleClass="muted-label"/>
                        </VBox>
                    </HBox>

                    <!-- ===== Frugal Briefing hero ===== -->
                    <VBox spacing="10" styleClass="surface-card hero-card">
                        <Label text="Frugal Briefing" styleClass="section-title"/>
                        <Label fx:id="briefingLabel" wrapText="true"
                               styleClass="hero-copy"
                               text="Your basket is cheapest at Aldi this week."/>
                        <Label fx:id="statusLabel" wrapText="true"
                               text="Ready. Search real products or add a local item."
                               styleClass="status-pill"/>
                    </VBox>

                    <!-- ===== Two-column input row ===== -->
                    <HBox spacing="18">
                        <VBox HBox.hgrow="ALWAYS" minWidth="360"
                              spacing="12" styleClass="surface-card">
                            <Label text="Quick Add to Local Database"
                                   styleClass="section-title"/>
                            <HBox spacing="10">
                                <TextField fx:id="quickAddField"
                                           promptText="Add a manual grocery item"
                                           HBox.hgrow="ALWAYS" styleClass="app-input"/>
                                <Button text="Quick Add" onAction="#handleQuickAdd"
                                        styleClass="primary-button"/>
                            </HBox>
                            <Label text="Useful when building your demo data set or entering pantry items manually."
                                   wrapText="true" styleClass="muted-label"/>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS" minWidth="360"
                              spacing="12" styleClass="surface-card">
                            <Label text="Search Real Product Data"
                                   styleClass="section-title"/>
                            <HBox spacing="10">
                                <TextField fx:id="searchField"
                                           promptText="Try milk, bread, eggs, rice"
                                           HBox.hgrow="ALWAYS" styleClass="app-input"/>
                                <Button fx:id="searchButton" text="Search"
                                        onAction="#handleSearch"
                                        styleClass="primary-button"/>
                            </HBox>
                            <ListView fx:id="resultsListView" prefHeight="220"
                                      VBox.vgrow="ALWAYS" styleClass="soft-list"/>
                            <Button text="Import Selected Product"
                                    onAction="#handleImportSelected"
                                    styleClass="secondary-button"/>
                        </VBox>
                    </HBox>

                    <!-- ===== Local items + talking points ===== -->
                    <HBox spacing="18">
                        <VBox HBox.hgrow="ALWAYS" minWidth="420"
                              spacing="12" styleClass="surface-card">
                            <Label text="Local Items in SQLite"
                                   styleClass="section-title"/>
                            <ListView fx:id="localItemsListView" prefHeight="260"
                                      VBox.vgrow="ALWAYS" styleClass="soft-list"/>
                        </VBox>

                        <VBox prefWidth="340" minWidth="300"
                              spacing="10" styleClass="surface-card">
                            <Label text="Next Demo Talking Points"
                                   styleClass="section-title"/>
                            <Label text="• Real-data import flow via Open Food Facts"
                                   wrapText="true" styleClass="muted-label"/>
                            <Label text="• SQLite persists imported and manual items"
                                   wrapText="true" styleClass="muted-label"/>
                            <Label text="• UI shell covers all eight main views"
                                   wrapText="true" styleClass="muted-label"/>
                            <Label text="• Theme: AI helps students live and spend smarter"
                                   wrapText="true" styleClass="muted-label"/>
                            <Region VBox.vgrow="ALWAYS"/>
                            <HBox spacing="10">
                                <Button text="Shopping List" onAction="#goShoppingList"
                                        styleClass="secondary-button"/>
                                <Button text="Settings" onAction="#handleOpenSettings"
                                        styleClass="ghost-button"/>
                            </HBox>
                        </VBox>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
